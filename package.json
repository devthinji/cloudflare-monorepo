{
  "name": "cloudflare-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "bash scripts/dev-local.sh",
    "setup:dev": "bash scripts/setup-dev.sh",
    "type-check": "turbo run type-check",
    "validate": "bash scripts/validate.sh",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "bash -c 'export LOCAL_DB_PATH=$(bash scripts/d1-local-path.sh) && drizzle-kit studio'",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "npx wrangler d1 execute platform-db --local --file=apps/api/gateway/drizzle/seed/dev.sql --config=apps/api/gateway/wrangler.toml",
    "db:seed:remote": "npx wrangler d1 execute platform-db --remote --file=apps/api/gateway/drizzle/seed/dev.sql --config=apps/api/gateway/wrangler.toml",
    "db:seed-templates": "bash scripts/seed-templates.sh"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "drizzle-kit": "^0.31.10",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
