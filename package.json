{
  "name": "cloudflare-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "bash scripts/dev-local.sh",
    "deploy": "turbo run deploy",
    "type-check": "turbo run type-check",
    "validate": "bash scripts/validate.sh",
    "deploy:api": "turbo run deploy --filter=@repo/api-*",
    "deploy:web": "turbo run deploy --filter=@repo/web-*",
    "dev:gateway": "turbo run dev --filter=@repo/api-gateway",
    "dev:agent": "turbo run dev --filter=@repo/api-agent",
    "dev:docgen": "turbo run dev --filter=@repo/api-docgen",
    "dev:payments": "turbo run dev --filter=@repo/api-payments",
    "dev:aaf": "turbo run dev --filter=@repo/web-aaf",
    "dev:dashboard": "turbo run dev --filter=@repo/web-dashboard",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "bash -c 'export LOCAL_DB_PATH=$(bash scripts/d1-local-path.sh) && drizzle-kit studio'",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "drizzle-kit": "^0.31.10",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
