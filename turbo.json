{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".wrangler/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "db:generate": { "cache": false },
    "db:push":     { "cache": false },
    "db:migrate":  { "cache": false },
    "db:studio":   { "cache": false, "persistent": true }
  }
}
