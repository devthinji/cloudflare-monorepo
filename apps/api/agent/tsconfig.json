{
  "extends": "agents/tsconfig",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2021"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@repo/types": ["../../packages/types/src/index.ts"],
      "@repo/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
