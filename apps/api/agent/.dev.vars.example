# ─── Secrets ───────────────────────────────────────────────────────────────────
# Copy this file to .dev.vars and fill in your values.
# .dev.vars is gitignored — keep it out of version control.

GROQ_API_KEY="gsk_your_groq_api_key_here"
JWT_SECRET="a_random_secret_key_at_least_32_chars_long"

