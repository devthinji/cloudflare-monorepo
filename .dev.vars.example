# ─── Root .dev.vars.example ─────────────────────────────────────────────────────
#
# This monorepo uses per-worker .dev.vars files for local development secrets.
# Each worker has its own .dev.vars.example — copy it to .dev.vars and fill in
# your real values.
#
# ── API workers ────────────────────────────────────────────────────────────────
#
#   apps/api/agent/.dev.vars.example      OPENROUTER_API_KEY, JWT_SECRET
#   apps/api/gateway/.dev.vars.example     JWT_SECRET
#   apps/api/docgen/.dev.vars.example      OPENROUTER_API_KEY
#   apps/api/payments/.dev.vars.example    MPESA keys (consumer key, secret, passkey)
#
# ── Channel workers ────────────────────────────────────────────────────────────
#
#   apps/web/aaf/whatsapp/.dev.vars.example   WhatsApp Cloud API token + verify token
#   apps/web/aaf/sms/.dev.vars.example        Africa's Talking API key + username
#   apps/web/aaf/telegram/.dev.vars.example   Telegram bot token + webhook secret
#
# ── Quick start ────────────────────────────────────────────────────────────────
#
#   for f in apps/*/*/.dev.vars.example apps/web/aaf/*/.dev.vars.example; do
#     cp "$f" "${f%.example}"
#   done
#
# Then edit each .dev.vars with real values before running wrangler dev.
#
# ── D1 database ────────────────────────────────────────────────────────────────
#
# Staging DB: caanplatform-db-staging (11909a8f-d177-4a08-a48a-fef7ce0c2df3)
# All API workers share the same database.
# Migrations live under apps/api/agent/migrations/ and apps/api/docgen/migrations/.
